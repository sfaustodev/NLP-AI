# Vox Probabilis backend — environment template.
# Copy to .env (NEVER commit .env) and fill VOX_SECRET_SALT with real bytes.
#
#     cp .env.example .env
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
#     # paste that value into VOX_SECRET_SALT below

# --- Required ------------------------------------------------

# Used to hash client IPs before storing (sha256(ip + SALT), first 16 chars).
# Rotating this value invalidates rate-limit history. Keep stable in prod.
VOX_SECRET_SALT=CHANGE_ME_TO_32_RANDOM_BYTES_BASE64

# SQLite database file path. On the VPS this lives under /var/lib/voxprobabilis/.
# Locally, keep it relative to the project root for easy reset.
VOX_DB_PATH=./vox.db

# --- Optional (sane defaults) --------------------------------

VOX_LOG_LEVEL=INFO              # DEBUG / INFO / WARNING / ERROR
VOX_COOKIE_SECURE=false         # set to true only when served behind HTTPS
VOX_MAX_UPLOAD_MB=10
VOX_FREE_DAILY_QUOTA=3

# Public hostname (used for self-references, cookie domain, etc.).
VOX_HOSTNAME=voxprobabilis.com

# DEPLOY.md §4 liveness handling.
#   off     → API unchanged (default for v0.1)
#   boolean → /api/analyze returns liveness ∈ {human|synthetic|ambiguous}
#   full    → boolean + dedicated landing-page section + paper v2
# Unknown values fall back to "off".
VOX_LIVENESS_MODE=off

# DEPLOY.md §12.2 metrics endpoint key. Leave empty to disable /api/metrics.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
VOX_METRICS_KEY=

# Path to the v0.1 tool directory (served at /app).
# Relative paths resolve against the backend/ working directory.
VOX_STATIC_DIR=../landing_page

# Path to the 3-tab marketing landing directory (served at /).
# Relative paths resolve against the backend/ working directory.
VOX_MARKETING_DIR=../landing_page/marketing

# CORS is NOT needed in production (same-origin) but during local dev you may
# want to allow the HTML to be opened from file:// or a different port.
# Comma-separated list; leave empty to disable CORS.
VOX_CORS_ORIGINS=

# --- Cloudflare Origin TLS (reference only) ----------------
# Local copies of the origin cert + private key live in backend/secrets/
# (gitignored). nginx on the VPS reads them from /etc/ssl/voxprobabilis/
# (see landing_page/DEPLOY.md §3.4). The backend app itself does not load
# these — the variables exist only to document where the secrets sit.
VOX_TLS_CERT_PATH=./secrets/cloudflare_origin_cert.pem
VOX_TLS_KEY_PATH=./secrets/cloudflare_origin_key.pem
